# Unity YAML merge-friendly
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.playable text eol=lf
*.meta text eol=lf
*.asmdef text eol=lf
*.json text eol=lf
*.cs text eol=lf
*.shader text eol=lf
*.cginc text eol=lf

