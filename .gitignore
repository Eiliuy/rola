# Asset meta data should only be ignored when the corresponding asset is also ignored
# ![Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# [Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
[Aa]ssets/Plugins/Editor/JetBrains*

# IDE cache directories
.vs/
.vscode/
.idea/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Unity IAP / Billing auto-generated
/[Aa]ssets/[Rr]esources/BillingMode.json
/[Aa]ssets/[Rr]esources/BillingMode.json.meta

# Local AI tooling runtime data
.funplay/
.claude/settings.local.json

# Asset crawler downloads (large raw assets, keep manifest only if needed)
tools/asset-crawlers/downloads/
tools/asset-crawlers/__pycache__/
tools/asset-crawlers/asset_crawlers/__pycache__/

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Kenney raw zip downloads (already organized under Assets)
tools/asset-crawlers/downloads/kenney/
tools/asset-crawlers/_unpack_temp/
